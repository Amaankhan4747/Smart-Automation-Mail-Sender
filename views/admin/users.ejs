<%- include('../partials/header') %>
<%- include('../partials/topbar', { caption: 'View, promote, or deactivate any user in the system.' }) %>

<div class="card">
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>#</th>
          <th>Name</th>
          <th>Email</th>
          <th>Templates</th>
          <th>Emails Sent</th>
          <th>Role</th>
          <th>Status</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody>
        <% users.forEach((u, i) => { %>
        <tr>
          <td class="cell-muted"><%= i + 1 %></td>
          <td class="cell-strong"><%= u.name %></td>
          <td class="cell-muted"><%= u.email %></td>
          <td><%= templateCountMap[u._id] || 0 %></td>
          <td><%= emailCountMap[u._id] || 0 %></td>
          <td><span class="badge badge-role-<%= u.role %>"><%= u.role %></span></td>
          <td><span class="badge <%= u.isActive ? 'badge-active' : 'badge-inactive' %>"><%= u.isActive ? 'Active' : 'Inactive' %></span></td>
          <td class="actions-cell">
            <% if (String(u._id) !== String(currentUser._id)) { %>
              <form action="/admin/users/<%= u._id %>/role" method="POST" style="display:inline;">
                <select name="role" onchange="this.form.submit()" class="btn-sm" style="padding:6px 8px; border-radius:8px; border:1.5px solid var(--border-soft);">
                  <option value="admin" <%= u.role === 'admin' ? 'selected' : '' %>>Admin</option>
                  <option value="user" <%= u.role === 'user' ? 'selected' : '' %>>User</option>
                  <option value="viewer" <%= u.role === 'viewer' ? 'selected' : '' %>>Viewer</option>
                </select>
              </form>
              <form action="/admin/users/<%= u._id %>/toggle-active" method="POST" style="display:inline;">
                <button type="submit" class="btn btn-sm <%= u.isActive ? 'btn-danger' : 'btn-outline' %>">
                  <%= u.isActive ? 'Deactivate' : 'Activate' %>
                </button>
              </form>
            <% } else { %>
              <span class="cell-muted">You</span>
            <% } %>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<%- include('../partials/footer') %>
