<%- include('../partials/header') %>
<%- include('../partials/topbar', { caption: 'Add a job profile with its subject, email content and resume.' }) %>

<div class="card" style="max-width: 720px;">
  <form action="/templates" method="POST" enctype="multipart/form-data">
    <div class="form-group">
      <label for="jobProfile">Job Profile</label>
      <input type="text" id="jobProfile" name="jobProfile" placeholder="e.g. React.js Developer" required />
    </div>

    <div class="form-group">
      <label for="subject">Email Subject</label>
      <input type="text" id="subject" name="subject" placeholder="e.g. Application for React.js Developer" required />
    </div>

    <div class="form-group">
      <label for="content">Email Content</label>
      <textarea id="content" name="content" placeholder="Dear HR, I hope you are doing well…" required></textarea>
    </div>

    <div class="form-group">
      <label for="resume">Resume (PDF)</label>
      <input type="file" id="resume" name="resume" accept="application/pdf" required />
      <div class="hint">PDF only, up to 5MB. This resume attaches automatically whenever this profile is selected.</div>
    </div>

    <div class="actions-cell">
      <button type="submit" class="btn btn-primary">Save Template</button>
      <a href="/templates" class="btn btn-outline">Cancel</a>
    </div>
  </form>
</div>

<%- include('../partials/footer') %>
